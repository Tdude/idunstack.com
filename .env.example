# ============================================================
# .env.example — copy to .env.<SITE_NAME> and fill in values
# Never commit the real .env.<SITE_NAME> file (it is gitignored)
# ============================================================

# ── Site identity ─────────────────────────────────────────
SITE_NAME=idunworks
COMPOSE_PROJECT_NAME=idunworkscom
PORT_OFFSET=40

# ── Public URLs (used at build-time and at runtime) ───────
PUBLIC_SITE_URL=https://example.com
# URL that browsers use to reach the main API (via reverse proxy)
PUBLIC_API_URL=https://api.example.com/api/v1

# ── Analytics (optional, leave blank to disable) ──────────
PUBLIC_ANALYTICS_URL=
PUBLIC_ANALYTICS_TEAM_ID=
PUBLIC_UMAMI_WEBSITE_ID=

# ── Feature flags ─────────────────────────────────────────
PUBLIC_ENABLE_ELEARNING=true
PUBLIC_ENABLE_SHOP=true
PUBLIC_ENABLE_SKIIN=true
ENABLE_ELEARNING=true
ENABLE_SHOP=true

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=idundb
POSTGRES_USER=idunuser
# Use a long random value: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── Stripe (shop) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Skjold auth service ───────────────────────────────────
SKJOLD_ADMIN_EMAIL=admin@example.com
# Use a strong password: openssl rand -base64 24
SKJOLD_ADMIN_PASSWORD=CHANGE_ME_strong_random_password
# Set to 1 only when you need to force-reset the admin account
SKJOLD_ADMIN_RESET=0

# ── AI assistant (Hugin) ──────────────────────────────────
XAI_API_KEY=
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ── CORS (skiin-api) ──────────────────────────────────────
# Comma-separated list of allowed origins, e.g. https://example.com
ALLOWED_ORIGINS=https://example.com

# ── E-learning media ──────────────────────────────────────
ELEARNING_MEDIA_STORAGE=local
ELEARNING_MAX_VIDEO_SIZE_MB=500
ELEARNING_CERTIFICATE_ENABLED=true

# ── CSRF protection ───────────────────────────────────────
# MUST be 0 in production. Set to 1 only for local dev with a non-standard proxy.
DISABLE_CSRF_CHECK=0
